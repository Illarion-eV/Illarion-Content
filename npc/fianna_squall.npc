-- STONEWEAVE ADVANCEMENT II
queststatus(692) > 4, queststatus(697) = 2, "Stone" -> queststatus(697) = 3, "Enter the Liberty Quarry, where the stones remember every hand. Find a silent place in the mine and sit among the ancient rocks to listen for Stoneweave's echoes.", inform("[Hint] Find a calm place in the Liberty Quarry and listen by sitting among the stones.")
queststatus(692) > 4, queststatus(697) = 2, "Stein" -> queststatus(697) = 3, "Betritt den Steinbruch der Freiheit, wo die Steine sich an jede Hand erinnern. Finde einen stillen Ort in der Mine und setze dich zwischen die uralten Felsen, um den Echos des Stoneweaves zu lauschen.", inform("[Hinweis] Finde einen ruhigen Ort im Steinbruch der Freiheit und lausche, indem du dich zwischen die Steine setzt.")
-- Repeated instructions
queststatus(697) = 3, "Stone" -> "Enter the Liberty Quarry, where the stones remember every hand. Find a silent place in the mine and sit among the ancient rocks to listen for Stoneweave's echoes.", inform("[Hint] Find a calm place in the Liberty Quarry and listen by sitting among the stones.")
queststatus(697) = 3, "Stein" -> "Betritt den Steinbruch der Freiheit, wo die Steine sich an jede Hand erinnern. Finde einen stillen Ort in der Mine und setze dich zwischen die uralten Felsen, um den Echos des Stoneweaves zu lauschen.", inform("[Hinweis] Finde einen ruhigen Ort im Steinbruch der Freiheit und lausche, indem du dich zwischen die Steine setzt.")
-- The player heads off to meditate and gather the rotten tree bark before returning
queststatus(697) = 4, item(5319, all) > 0, item(157, all) > 9, "stone" -> queststatus(697) = 5, "I see stone has whispered to you. Carry the rotten tree bark, along with your blank sigil, to the southeast of the Cornerstone of Candour. There among rocks and scorching sun, search the stoneweaver's stump to craft your Stone Sigil.", inform("[Hint] Bring ten rotten tree bark and a blank sigil to the southeast of the Cornerstone of Candour, where you will find a stoneweaver's stump to craft a Basic Stoneweaver's Sigil.")
queststatus(697) = 4, item(5319, all) > 0, item(157, all) > 9, "Stein" -> queststatus(697) = 5, "Ich sehe, der Stein hat zu dir gesprochen. Trage die faulige Baumrinde zusammen mit deinem leeren Siegel s³d÷stlich des Ecksteins der Aufrichtigkeit. Dort, zwischen Felsen und sengender Sonne, suche den Steinweber-Stumpf auf, um dein Steinsiegel zu fertigen.", inform("[Hinweis] Bringe zehn faulige Baumrinde und ein leeres Siegel s³d÷stlich des Ecksteins der Aufrichtigkeit, wo du einen Steinweber-Stumpf findest, um ein einfaches Steinwebersiegel herzustellen.")
-- The player does not have enough rotten tree bark or a blank sigil
queststatus(697) = 4, "stone" -> "NOT ENOUGH BLANK SIGIL/ROTTEN TREE BARK PLACEHOLDER" --TODO
-- When the player goes and crafts the sigil, their quest status will update from 5 to 6 allowing them to continue to the step below.
-- If this is your first weave, we also activate the continuation of the general tutorial for weave pouch/cor staff/casting/ seekers cauldron.
queststatus(697) = 6, queststatus(692) = 5, "stone"-> queststatus(697) = 7, queststatus(692) = 6, "Stone's memory and patience are now your strength. Look to the Seer's Cauldron when you seek further wisdom in Stoneweave.", inform("[Hint] Ask about the 'seer's cauldron' to discover further Stoneweave.")
queststatus(697) = 6, queststatus(692) = 5, "Stein"-> queststatus(697) = 7, queststatus(692) = 6, "Das Gedõchtnis und die Geduld des Steins sind nun deine Stõrke. Wende dich dem Seer's Cauldron zu, wenn du nach weiterem Wissen im Stoneweave suchst.", inform("[Hinweis] Frage nach dem 'Seer's Cauldron', um weiteres Stoneweave zu entdecken.")
-- Otherwise we just update the quest status to allow you to see new spells in the seer cauldron for this weave
queststatus(697) = 6, "stone"-> queststatus(697) = 7, "Stone's memory and patience are now your strength. Look to the Seer's Cauldron when you seek further wisdom in Stoneweave.", inform("[Hint] Ask about the 'seer's cauldron' to discover further Stoneweave.")
queststatus(697) = 6, "Stein"-> queststatus(697) = 7, "Das Gedõchtnis und die Geduld des Steins sind nun deine Stõrke. Wende dich dem Seer's Cauldron zu, wenn du nach weiterem Wissen im Stoneweave suchst.", inform("[Hinweis] Frage nach dem 'Seer's Cauldron', um weiteres Stoneweave zu entdecken.")

