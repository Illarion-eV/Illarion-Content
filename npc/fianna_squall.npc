-- DEEPWEAVE ADVANCEMENT II
-------------------------------------------------------------------------------
-- Deepweave is in the lore a more dangerous weave, and the location of its stump and meditation spot is too. As such gated behind the other weaves.
-- If all other four weave tutorials are taken to completion we start the deepweave tutorial
queststatus(692) > 4, queststatus(695) = 2, queststatus(693) > 6, queststatus(694) > 6, queststatus(696) > 6, queststatus(697) > 6, "Deep" -> queststatus(695) = 3, "Descend into Ushara's paradise, where roots knot in living darkness. Sit within those silent groves and listen for the oldest song.", inform("[Hint] Find Ushara's hidden underground grove and listen to the earth's deepest root.")
queststatus(692) > 4, queststatus(695) = 2, queststatus(693) > 6, queststatus(694) > 6, queststatus(696) > 6, queststatus(697) > 6, "Tief" -> queststatus(695) = 3, "Steige hinab in Usharas Paradies, wo sich Wurzeln in lebendiger Dunkelheit winden. Setze dich in diese stillen Haine und lausche dem õltesten Lied.", inform("[Hinweis] Finde Usharas verborgenen unterirdischen Hain und lausche der tiefsten Wurzel der Erde.")
-- Guidance to learn more about the other four weaves first if you havent gone through their tutorials yet
queststatus(692) > 4, queststatus(695) = 2, "Deep" -> "You sense the Deepweave stirring, but its path is not yet ready. Establish yourself in Wither, Bloom, Wild, and Stone before seeking the deep mystery.", inform("[Hint] Advance your understanding in the other Cor Weaves before you walk the Deep.")
queststatus(692) > 4, queststatus(695) = 2, "Tief" -> "Du sp³rst das Erwachen des Deepweave, doch sein Pfad ist noch nicht bereit. Festige dich in Wither, Bloom, Wild und Stone, bevor du das tiefe Mysterium suchst.", inform("[Hinweis] Vertiefe dein Verstõndnis der anderen Cor Weaves, bevor du den Deep beschreitest.")
-- Repeated instructions
queststatus(695) = 3, "Deep" -> "Descend into Ushara's paradise, where roots knot in living darkness. Sit within those silent groves and listen for the oldest song.", inform("[Hint] Find Ushara's hidden underground grove and listen to the earth's deepest root.")
queststatus(695) = 3, "Tief" -> "Steige hinab in Usharas Paradies, wo sich Wurzeln in lebendiger Dunkelheit winden. Setze dich in diese stillen Haine und lausche dem õltesten Lied.", inform("[Hinweis] Finde Usharas verborgenen unterirdischen Hain und lausche der tiefsten Wurzel der Erde.")
-- The player heads off to meditate and gather the bulbsponge mushroom before returning
queststatus(695) = 4, item(5319, all) > 0, item(158, all) > 9, "Deep" -> queststatus(695) = 5, "I see the Deep spoke to you. Now, take your bulsponge mushrooms and a blank sigil to the Forgotten Weaver's Stump. Search north of Elstree, look for an abandoned underground shaft where fox cubs reside. There you will find solace and the relic to craft your Basic Deepweave Sigil.", inform("[Hint] Bring ten bulbsponge mushrooms and a blank sigil to the secluded underground with foxes you'll find north of the Elstree Forest.")
queststatus(695) = 4, item(5319, all) > 0, item(158, all) > 9, "Tief" -> queststatus(695) = 5, "Ich sehe, der Deep hat zu dir gesprochen. Nun nimm deine Knollenschwammpilze und ein leeres Siegel und bringe sie zum Vergessenen Weberstumpf. Suche n÷rdlich von Elstree nach einem verlassenen unterirdischen Schacht, in dem Fuchswelpen leben. Dort findest du Ruhe und das Relikt, um dein einfaches Deepweave-Siegel zu fertigen.", inform("[Hinweis] Bringe zehn Knollenschwammpilze und ein leeres Siegel in die abgelegene unterirdische H÷hle mit F³chsen, die du n÷rdlich des Elstree-Waldes findest.")
-- The player does not have enough bulbsponge mushroom or a blank sigil
queststatus(695) = 4, "deep" -> "NOT ENOUGH BLANK SIGIL/BULBSPONGE MUSHROOM PLACEHOLDER" --TODO
-- Deepweave cant be your first weave so we just update the quest status to allow you to see new spells in the seer cauldron for this weave
queststatus(695) = 6, "deep"-> queststatus(695) = 7, "You walk with the shadow beneath roots. In time, the Seer's Cauldron may reveal more secrets of Deepweave, now you are trusted with its mysteries.", inform("[Hint] Ask about the 'seer's cauldron' to seek the Deep's further wisdom.")
queststatus(695) = 6, "deep"-> queststatus(695) = 7, "Du gehst mit dem Schatten unter den Wurzeln. Mit der Zeit k÷nnte der Seer's Cauldron weitere Geheimnisse des Deepweave offenbaren, nun bist du seinen Mysterien anvertraut.", inform("[Hinweis] Frage nach dem 'Seer's Cauldron', um weitere Weisheit des Deep zu suchen.")
